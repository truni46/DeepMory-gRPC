# ============================
# DeepMory — Server Config
# ============================

# --- Database ---
USE_DATABASE=true
DB_HOST=localhost
DB_PORT=5432
DB_NAME=deepmory_db
DB_USER=deepmory
DB_PASSWORD=deepmory_pass

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=deepmory_pass

# --- LLM ---
LLM_PROVIDER=gemini                # openai | gemini | gemini_native | ollama | vllm
LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434/v1
VLLM_BASE_URL=http://localhost:8000/v1

# --- Embedding ---
EMBEDDING_PROVIDER=ollama          # ollama | openai | generic
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024
OPENAI_EMBEDDING_API_KEY=          # for openai provider, falls back to OPENAI_API_KEY
EMBEDDING_BASE_URL=                # for generic provider (OpenAI-compatible endpoint)

# --- Qdrant (Vector DB) ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- Neo4j (Knowledge Graph) ---
NEO4J_URL=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=deepmory_pass

# --- LightRAG ---
LIGHTRAG_QUERY_MODE=hybrid         # naive | local | global | hybrid
LIGHTRAG_CHUNK_SIZE=1200
LIGHTRAG_CHUNK_OVERLAP=100
LIGHTRAG_STORAGE_DIR=./rag_storage

# --- Memory ---
CONV_SUMMARY_THRESHOLD=4000
CONV_WINDOW_SIZE=10
MEMORY_EXTRACTION_ENABLED=true
REDIS_CONV_WINDOW_TTL=3600
REDIS_SUMMARY_TTL=86400

# --- Token Quota ---
TOKEN_SESSION_LIMIT=500000
TOKEN_SESSION_DURATION=7200
TOKEN_WEEKLY_LIMIT=5000000
TOKEN_WARNING_THRESHOLD=0.9

# --- Auth ---
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Server ---
PORT=3000
HOST=0.0.0.0
FRONTEND_URL=http://localhost:5173
