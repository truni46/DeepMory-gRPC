# VITE Environment Variables

# API Base URL (backend server)
VITE_API_URL=http://localhost:3000/api/v1

# WebSocket URL (Socket.IO server)
VITE_SOCKET_URL=http://localhost:3000

# Backend Variables (Can be same file or server/.env)

# Server Configuration
PORT=3000
HOST=0.0.0.0
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
USE_DATABASE=true
DB_HOST=localhost
DB_PORT=5432
DB_NAME=deepmory_db
DB_USER=deepmory
DB_PASSWORD=your_password

# Redis (Cache)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Auth
JWT_SECRET=change-this-to-a-secure-random-secret

# LLM Configuration
# Options: ollama, openai, gemini, vllm
LLM_PROVIDER=ollama
LLM_MODEL=mistral

# Provider Specifics
# Ollama
OLLAMA_BASE_URL=http://localhost:11434/v1

# OpenAI
OPENAI_API_KEY=sk-...

# Gemini
GEMINI_API_KEY=...

# vLLM
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=EMPTY

# Agent System
AGENT_MAX_ITERATIONS=10
AGENT_WORKSPACE_DIR=./agent_workspace
AGENT_SHELL_TIMEOUT=30
TAVILY_API_KEY=tvly-...

# Vector DB (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Embedding
# Options: ollama, openai, generic
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024
# For openai: OPENAI_EMBEDDING_API_KEY=sk-...
# For generic: EMBEDDING_BASE_URL=http://localhost:8000/v1, EMBEDDING_API_KEY=EMPTY

# RAG Provider
# Options: simple (direct Qdrant + embeddings, no extra deps) | lightrag (requires Neo4j)
RAG_PROVIDER=simple

# Token Quota
TOKEN_SESSION_LIMIT=500000
TOKEN_SESSION_DURATION=7200
TOKEN_WEEKLY_LIMIT=5000000
TOKEN_WARNING_THRESHOLD=0.9

# gRPC Microservices
# Set *_USE_GRPC=true to route calls through gRPC instead of local
RAG_USE_GRPC=false
RAG_GRPC_HOST=localhost
RAG_GRPC_PORT=50051

MEMORY_USE_GRPC=false
MEMORY_GRPC_HOST=localhost
MEMORY_GRPC_PORT=50052

AGENTS_USE_GRPC=false
AGENTS_GRPC_HOST=localhost
AGENTS_GRPC_PORT=50053
